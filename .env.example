# API key for authenticating /extract requests (required)
APP_API_KEY=your-secret-key-here

# LLM Provider: "anthropic" (default), "openai", or "ollama"
APP_LLM_PROVIDER=anthropic

# Optional: override the default model for the chosen provider
# Defaults: anthropic=claude-haiku-4-5-20251001, openai=gpt-4.1-mini, ollama=qwen2.5:7b
# APP_LLM_MODEL=

# Anthropic (required when APP_LLM_PROVIDER=anthropic)
APP_ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (required when APP_LLM_PROVIDER=openai)
APP_OPENAI_API_KEY=sk-...

# Ollama (only needed when APP_LLM_PROVIDER=ollama)
# APP_OLLAMA_BASE_URL=http://ollama:11434

# General settings
# APP_REQUEST_TIMEOUT=120.0
# APP_MAX_RETRIES=2
# APP_MAX_UPLOAD_SIZE_MB=50
